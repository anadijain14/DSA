#include <iostream>
using namespace std;

string replaceCharacters(string s) {
    for (int i = 0; i < s.length(); i++) {
        if (i % 2 == 0) {
            // Even index → next ASCII
            s[i] = s[i] + 1;
        } else {
            // Odd index → previous ASCII
            s[i] = s[i] - 1;
        }
    }
    return s;
}

int main() {
    string S;
    cin >> S;

    cout << replaceCharacters(S);

    return 0;
}